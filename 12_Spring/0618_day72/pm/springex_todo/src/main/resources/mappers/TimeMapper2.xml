<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kb.springex.mapper.TimeMapper2">
    <!-- MyBatis 별칭 사용 가능! -->
    <!-- java.lang.String => string -->
    <!--    <select id="getTimeNow" resultType="java.lang.String">-->
    <!-- 대소문자 구분하기 때문에 함수명 대소문자 그대로 작성해야 함 -->
    <select id="getTimeNow" resultType="string">
        SELECT now()
    </select>
</mapper>