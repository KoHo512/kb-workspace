<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.scoula.board.mapper.BoardMapper">

    <!-- TODO 1: tbl_board 컬럼과 BoardVO 필드를 연결하는 resultMap을 완성하세요. -->
    <resultMap id="boardMap" type="org.scoula.board.domain.BoardVO">
        <id column="no" property="no"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="writer" property="writer"/>
        <result column="reg_date" property="regDate"/>
        <result column="update_date" property="updateDate"/>
    </resultMap>

    <!-- TODO 2: 게시글 목록 조회 SQL을 작성하세요. -->
    <select id="getList" resultMap="boardMap">
        SELECT no, title, content, writer, reg_date, update_date
        FROM tbl_board
        ORDER BY no DESC
    </select>

    <!-- TODO 3: 게시글 상세 조회 SQL을 작성하세요. -->
    <select id="get" resultMap="boardMap">
        SELECT no, title, content, writer, reg_date, update_date
        FROM tbl_board
        WHERE no = #{no}
    </select>

    <!-- TODO 4: 게시글 등록 SQL을 작성하세요. useGeneratedKeys와 keyProperty도 설정하세요. -->
    <insert id="create" useGeneratedKeys="true" keyProperty="no">
        INSERT INTO tbl_board(title, content, writer)
        VALUES(#{title}, #{content}, #{writer})
    </insert>

    <!-- TODO 5: 게시글 수정 SQL을 작성하세요. -->
    <update id="update">
        UPDATE tbl_board
        SET title = #{title},
            content = #{content},
            writer = #{writer},
            update_date = NOW()
        WHERE no = #{no}
    </update>

    <!-- TODO 6: 게시글 삭제 SQL을 작성하세요. -->
    <delete id="delete">
        DELETE FROM tbl_board
        WHERE no = #{no}
    </delete>
</mapper>
